{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1.13",
        "bacon/bacon-qr-code": "^2.0",
        "cartalyst/stripe-laravel": "^15.0",
        "doctrine/dbal": "^3.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "jackiedo/dotenv-editor": "^2.1",
        "joedixon/laravel-translation": "^2.0",
        "kevupton/laravel-coinpayments": "^0.2.9",
        "laravel/framework": "^10.0",
        "laravel/legacy-factories": "^1.3",
        "laravel/passport": "^11.0",
        "laravel/sanctum": "^3.2",
        "laravel/tinker": "^2.0",
        "laravel/ui": "^4.2",
        "nesbot/carbon": "^2.36",
        "paypal/rest-api-sdk-php": "^1.6",
        "pragmarx/google2fa-laravel": "^2.1",
        "realrashid/sweet-alert": "^7.1",
        "renatomarinho/laravel-page-speed": "dev-master",
        "stripe/stripe-php": "^10.19",
        "symfony/google-mailer": "^6.3",
        "symfony/mailchimp-mailer": "^6.3",
        "symfony/mailer": "^6.3",
        "symfony/mailgun-mailer": "^6.3",
        "symfony/postmark-mailer": "^6.3",
        "symfony/sendgrid-mailer": "^6.3",
        "symfony/sendinblue-mailer": "^6.3",
        "symfony/twig-bundle": "^6.3",
        "unicodeveloper/laravel-paystack": "^1.0",
        "yarcode/yii2-payeer": "~1.0"
    },
    "require-dev": {
        "beyondcode/laravel-dump-server": "^1.0",
        "filp/whoops": "^2.0",
        "spatie/laravel-ignition": "^2.0",
        "mockery/mockery": "^1.0",
        "nunomaduro/collision": "^7.0",
        "phpunit/phpunit": "^10.0",
        "mashape/unirest-php": ">= 3.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "yiisoft/yii2-composer": false
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "ZaLaravel\\LaravelPayeer\\": "app/src/ZaLaravel/LaravelPayeer",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Http/Helpers/helpers.php",
            "app/Exceptions/ErrorHandler/ErrorHandler.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
   
}
